# Cấu hình Server (Mẫu)
PORT=3001

# Database (Localhost)
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=iot
DB_HOST=localhost
DB_PORT=5432

# Database (Production/Supabase)
# Render/Supabase thường cung cấp DATABASE_URL thay vì các biến rời
DATABASE_URL=postgresql://user:password@host:port/dbname

# IoT Config
DEFAULT_DEVICE_ID=esp32_01
IOT_API_KEY=your_secret_api_key

# Authentication
JWT_SECRET=your_super_secret_jwt_key

# Email Alert Config
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password_from_google
EMAIL_RECEIVER=receiver_email@gmail.com
